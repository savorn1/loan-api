# Copy this file to .env on the server and fill in real values.
# .env is gitignored — never commit the real one.

# Domain Caddy will request a TLS cert for (must already point at this server's IP).
# For local/no-DNS testing, use ":80" to serve plain HTTP on port 80 instead.
DOMAIN=example.com

# Postgres password used by every service's datasource.
# Generate with: openssl rand -base64 24
POSTGRES_PASSWORD=changeme

# Redis password (customer-service rate limiting).
# Generate with: openssl rand -base64 24
REDIS_PASSWORD=changeme

# JWT signing secret shared by api-gateway and auth-service.
# Must be different from the dev secret committed in application.yml/.properties.
# Generate with: openssl rand -base64 48
JWT_SECRET=changeme
